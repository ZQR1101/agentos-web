# Copy this file to .env.local and add your own API key. Never commit .env.local.
DEEPSEEK_API_KEY=
# Optional: override the model used by the server route.
DEEPSEEK_MODEL=deepseek-v4-flash

# Get a key from https://app.tavily.com. Used only after user approval.
TAVILY_API_KEY=

# Optional: expose the Research MCP over authenticated Streamable HTTP.
# Use a long random value and configure the exact hosts that may serve the endpoint.
MCP_ACCESS_TOKEN=
MCP_ALLOWED_HOSTS=localhost:3000,127.0.0.1:3000
