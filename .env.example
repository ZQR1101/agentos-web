# GitHub App is optional for public repositories. For private repositories, create
# a GitHub App with Metadata: Read and Contents: Read, install it only on selected
# repositories, and base64-encode its PEM private key before placing it here.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=
# JSON map from GitHub App installation ID to AgentOS organizationId.
GITHUB_INSTALLATION_ORGANIZATION_MAP={}
GITHUB_WEBHOOK_BUG_LABEL=agentos:triage

# Optional production task persistence. Leave DATABASE_URL empty for local JSON mode.
DATABASE_URL=
AGENTOS_DB_POOL_SIZE=10

# Set false when `npm run worker` runs as a separate process.
AGENTOS_INLINE_WORKER=true
AGENTOS_WORKER_CONCURRENCY=2
AGENTOS_WORKER_POLL_MS=1000
# Optional health-check/debug mode: poll once and exit.
AGENTOS_WORKER_ONCE=false

# Approval identity. In production, the authentication gateway must strip any
# client-supplied x-agentos-* headers and inject verified identity headers.
AGENTOS_TRUST_IDENTITY_HEADERS=false
AGENTOS_IDENTITY_HEADER_SECRET=
AGENTOS_LOCAL_APPROVER_ID=local-admin
AGENTOS_LOCAL_APPROVER_NAME=Local Administrator
AGENTOS_LOCAL_APPROVER_ROLES=approver
AGENTOS_LOCAL_ORGANIZATION_ID=local
AGENTOS_LEGACY_ORGANIZATION_ID=local

# The gateway must inject x-agentos-identity-secret and x-agentos-organization-id.
# Optional JSON policy. Rules are matched exact repository, then owner/*, then */*.
# AGENTOS_APPROVAL_POLICY_JSON={"version":"corp-v1","rules":[{"id":"acme-platform","repository":"acme/*","approverRoles":["platform-approver"],"allowedScopes":["github:read"]}]}
